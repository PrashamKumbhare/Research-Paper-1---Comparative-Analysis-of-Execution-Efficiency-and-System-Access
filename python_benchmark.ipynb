    "import time\n",
    "\n",
    "sum = 0\n",
    "\n",
    "start = time.time()\n",
    "\n",
    "for i in range(1, 100000001):\n",
    "    sum += i\n",
    "\n",
    "end = time.time()\n",
    "\n",
    "print(\"Sum:\", sum)\n",
    "print(\"Execution time:\", end - start, \"seconds\")"
   ]
